# Copy this file to .env and fill in your values
# Never commit .env to version control — only put real keys in .env

# --- Model Provider ---
# Which provider to use: "anthropic" or "openai"
MODEL_PROVIDER=anthropic

# --- Model Selection ---
# Anthropic: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
# OpenAI:    gpt-4o, gpt-4o-mini, gpt-4-turbo
MODEL_NAME=claude-sonnet-4-6

# --- API Keys (fill in only the one you need) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here


# --- Paths ---

DATA_DIR=./data
OUTPUT_DIR=./output
BATCH_TODO_DIR=./job_descriptions/TODO
COVER_LETTER_TEMPLATE_PATH=./data/cover_letter.md
COVER_LETTER_RUBRIC_PATH=./data/cover_letter_rubric.md

# inside of a docker container, this path should be within the container e.g. app/output
OBSIDIAN_LIST_PATH=~/Documents/vault/thoughts-and-dreams/Job_hunt/job_applications/application_status/ 
OBSIDIAN_VAULT_PATH=/app/output

# --- Constants ---

MATCH_SCORE_THRESHOLD=60
BATCH_DELAY_SECONDS=2